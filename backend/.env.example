# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://omar:omar_secret@localhost:5432/omar_clinic_pro?schema=public

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OTP
OTP_EXPIRES_MINUTES=10

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
STORAGE_MAX_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000

# WhatsApp (configure with your provider)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
